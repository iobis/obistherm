# Copy to .env and fill in before running docker compose

# Root directory on the host where all data lives
DATA_ROOT=/Volumes/OBIS2

# Copernicus Marine Service credentials
# https://data.marine.copernicus.eu/register
COPERNICUS_USER=your_username
COPERNICUS_PWD=your_password

# Retry settings (optional)
MAX_RETRIES=3
RETRY_DELAY=300
